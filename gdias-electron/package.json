{
  "name": "gdias-electron",
  "version": "1.0.0",
  "description": "GDIAS — Government Data Integration and Analysis System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "supabase": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "th.nectec.gdias",
    "productName": "GDIAS",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
